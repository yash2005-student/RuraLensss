# Server Configuration
PORT=3001
NODE_ENV=development

# Python GNN Model API URL
# Local development:
PYTHON_GNN_API_URL=http://localhost:8001
# Production example:
# PYTHON_GNN_API_URL=https://ruralens-gnn-api.onrender.com

# Pathway MCP Configuration
# Use port 8000 for real Pathway RAG server
PATHWAY_MCP_URL=http://localhost:8000/v1/pw_ai_answer
PATHWAY_MCP_TOKEN=mock_token_for_development
PATHWAY_INDEX_SOURCE=mongodb
PATHWAY_MONGODB_DB=villagetwin
PATHWAY_SCHEMES_COLLECTION=schemes
PATHWAY_REPORTS_COLLECTION=anonymousreports

# Pathway PDF extractor (python service) configuration
USE_PATHWAY_EXTRACTION=true
PATHWAY_EXTRACTOR_URL=http://localhost:8080

# RAG Cache Settings
RAG_CACHE_TTL_SECONDS=120

# RAG Query Limits
RAG_MAX_CITATIONS=5
PATHWAY_TIMEOUT_MS=20000

# MongoDB Configuration
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/villagetwin
# Or use MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=<appname>

# JWT Secret (IMPORTANT: Change this in production!)
JWT_SECRET=your-secret-key-change-this-in-production-2024

# Gemini AI API Key
# Get your free API key from: https://aistudio.google.com/app/apikey
# Free tier: 10 requests/min, 250K tokens/min, 250 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API Key (used by RAG + other backend AI features)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Default Admin Credentials (created on first run)
ADMIN_EMAIL=admin@village.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# Ringg AI Integration
# Base URL from Ringg API docs
RINGG_API_BASE_URL=https://prod-api.ringg.ai/ca/api/v0
# Your Ringg workspace API key
RINGG_API_KEY=your_ringg_api_key_here
# Default assistant (agent) ID for fetching latest call summaries
RINGG_ASSISTANT_ID=your_ringg_assistant_id_here
